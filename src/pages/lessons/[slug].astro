---
import Base from "../../layouts/Base.astro";
import SolutionPlayer from "../../islands/SolutionPlayer.svelte";
import StructureLesson from "../../components/StructureLesson.astro";
import ComparisonLesson from "../../components/ComparisonLesson.astro";
import EquilibriumLesson from "../../components/EquilibriumLesson.astro";
import PredictionLesson from "../../components/PredictionLesson.astro";
import KineticsLesson from "../../components/KineticsLesson.astro";
import ElectrochemistryLesson from "../../components/ElectrochemistryLesson.astro";
import { withBase } from "../../lib/withBase.js";
import { renderSolution, renderStructureLesson, renderComparisonLesson, renderEquilibriumLesson, renderPredictionLesson, renderKineticsLesson, renderElectrochemistryLesson } from "../../lib/view.js";
import { plain } from "../../lib/katex.js";

// One page per committed lesson JSON. Five lesson shapes share the /lessons/<slug>/ route: a reaction lesson
// (*.solution.json → SolutionPlayer, the extent ledger), a structure lesson (*.structure.json → StructureLesson,
// the single-molecule electron ledger, ADR-0045), a comparison lesson (*.comparison.json → ComparisonLesson,
// several molecules vs. a property, ADR-0047), an equilibrium lesson (*.equilibrium.json → EquilibriumLesson, the
// ICE table, ADR-0048), and a prediction lesson (*.prediction.json → PredictionLesson, the Q-vs-Kₛₚ precipitation
// snapshot, ADR-0048). The producer is the source of truth; this page only renders.
export function getStaticPaths() {
  const sols = import.meta.glob("../../../derived/**/*.solution.json", { eager: true });
  const structs = import.meta.glob("../../../derived/**/*.structure.json", { eager: true });
  const cmps = import.meta.glob("../../../derived/**/*.comparison.json", { eager: true });
  const eqs = import.meta.glob("../../../derived/**/*.equilibrium.json", { eager: true });
  const preds = import.meta.glob("../../../derived/**/*.prediction.json", { eager: true });
  const kins = import.meta.glob("../../../derived/**/*.kinetics.json", { eager: true });
  const echem = import.meta.glob("../../../derived/**/*.electrochemistry.json", { eager: true });
  return [
    ...Object.values(sols).map((m) => ({ params: { slug: m.default.slug }, props: { lesson: m.default, kind: "reaction" } })),
    ...Object.values(structs).map((m) => ({ params: { slug: m.default.slug }, props: { lesson: m.default, kind: "structure" } })),
    ...Object.values(cmps).map((m) => ({ params: { slug: m.default.slug }, props: { lesson: m.default, kind: "comparison" } })),
    ...Object.values(eqs).map((m) => ({ params: { slug: m.default.slug }, props: { lesson: m.default, kind: "equilibrium" } })),
    ...Object.values(preds).map((m) => ({ params: { slug: m.default.slug }, props: { lesson: m.default, kind: "prediction" } })),
    ...Object.values(kins).map((m) => ({ params: { slug: m.default.slug }, props: { lesson: m.default, kind: "kinetics" } })),
    ...Object.values(echem).map((m) => ({ params: { slug: m.default.slug }, props: { lesson: m.default, kind: "electrochemistry" } })),
  ];
}

const { lesson, kind } = Astro.props;
const isStructure = kind === "structure";
const isComparison = kind === "comparison";
const isEquilibrium = kind === "equilibrium";
const isPrediction = kind === "prediction";
const isKinetics = kind === "kinetics";
const isElectrochemistry = kind === "electrochemistry";
const view = isElectrochemistry ? renderElectrochemistryLesson(lesson)
  : isKinetics ? renderKineticsLesson(lesson)
  : isPrediction ? renderPredictionLesson(lesson)
  : isEquilibrium ? renderEquilibriumLesson(lesson)
  : isComparison ? renderComparisonLesson(lesson)
  : isStructure ? renderStructureLesson(lesson) : renderSolution(lesson);

const metaRaw = plain(lesson.scenario);
const metaDesc = metaRaw.length > 157 ? metaRaw.slice(0, 156).replace(/\s+\S*$/, "") + "…" : metaRaw;

// Concept chips link into the Chemical Atlas where they resolve — routed by the target entry's KIND to the
// page that hosts it (concept → the index; reaction-family / species / formula / molecule → their own pages),
// or, for an element or ion topic, to the Valence Table. Ids without an entry yet render as plain chips.
const refs = import.meta.glob("../../../derived/reference/*.json", { eager: true });
const byId = new Map(Object.values(refs).map((m) => [m.default.id, m.default]));
const valenceTopics = new Set(["calcium", "carbonate", "sodium", "chloride", "chlorine", "sulfate", "nitrate", "phosphate", "acetate", "ammonium", "hydroxide", "oxide"]);
const kindPage = { concept: "/reference/", "reaction-family": "/reference/reactions/", species: "/reference/species/", formula: "/reference/formulas/", molecule: "/reference/molecules/" };
const titleCase = (id) => id.split("-").map((w) => w[0].toUpperCase() + w.slice(1)).join(" ");
const concepts = (lesson.reference_links ?? []).map((id) => {
  const entry = byId.get(id);
  const page = entry && kindPage[entry.kind];
  return {
    id,
    label: entry?.title ?? titleCase(id),
    href: page ? withBase(`${page}#${id}`) : valenceTopics.has(id) ? withBase("/reference/valence-table/") : null,
  };
});
---

<Base title={`${lesson.title} — Affinity`} description={metaDesc}>
  <p class="crumb faint"><a href={withBase("/lessons/")}>Lessons</a> · {lesson.topic}</p>
  <h1>{lesson.title}</h1>

  {isElectrochemistry
    ? <ElectrochemistryLesson lesson={view} />
    : isKinetics
    ? <KineticsLesson lesson={view} />
    : isPrediction
    ? <PredictionLesson lesson={view} />
    : isEquilibrium
    ? <EquilibriumLesson lesson={view} />
    : isComparison
    ? <ComparisonLesson lesson={view} />
    : isStructure
    ? <StructureLesson lesson={view} />
    /* client:load (not client:visible): the player IS the lesson and sits above the fold; client:visible never
       hydrates in a headless preview loading at a 0×0 viewport (the IntersectionObserver never fires). */
    : <SolutionPlayer solution={view} client:load />}

  <section class="links">
    <h2>Concepts in this lesson</h2>
    <p class="muted">Linked into the <a href={withBase("/reference/")}>Chemical Atlas</a> where an entry exists;
      the rest fill in as the Atlas grows.</p>
    <ul class="chips">
      {concepts.map((c) => (
        <li class="chip">{c.href ? <a href={c.href}>{c.label}</a> : c.label}</li>
      ))}
    </ul>
  </section>

  <style>
    h1 { font-size: 1.9rem; }
    .crumb { margin-bottom: 0.3rem; }
    .links { margin-top: 2.5rem; }
    .chips { list-style: none; padding: 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .chip { background: var(--paper-sunk); color: var(--ink-2); padding: 0.25rem 0.65rem; border-radius: 999px; font-size: 0.85rem; }
  </style>
</Base>
