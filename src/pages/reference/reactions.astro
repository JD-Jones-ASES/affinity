---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/withBase.js";
import { renderReactionFamily } from "../../lib/view.js";

const refs = import.meta.glob("../../../derived/reference/*.json", { eager: true });
const all = Object.values(refs).map((m) => m.default);

// canonical teaching order: the five reaction types, then the double-replacement sub-types
const ORDER = ["combustion", "synthesis", "decomposition", "single-replacement",
               "double-replacement", "precipitation", "acid-base", "gas-evolution"];
const families = all
  .filter((r) => r.kind === "reaction-family")
  .map(renderReactionFamily)
  .sort((a, b) => ORDER.indexOf(a.family) - ORDER.indexOf(b.family));

const conceptTitle = Object.fromEntries(all.map((r) => [r.id, r.title]));
const sols = import.meta.glob("../../../derived/**/*.solution.json", { eager: true });
const structs = import.meta.glob("../../../derived/**/*.structure.json", { eager: true });
const cmps = import.meta.glob("../../../derived/**/*.comparison.json", { eager: true });
const lessonTitle = Object.fromEntries([...Object.values(sols), ...Object.values(structs), ...Object.values(cmps)].map((m) => [m.default.slug, m.default.title]));
---

<Base title="Reaction families — Affinity" description="The first-course reaction families, each with a general form, misconceptions, and machine-verified example reactions — balanced and classified by ChemKernel, with the net-ionic particle view.">
  <p class="crumb"><a href={withBase("/reference/")}>← Chemical Atlas</a></p>
  <h1>Reaction families</h1>
  <p class="muted lede">How chemists sort reactions by their pattern. Every example below is <strong>balanced and
    classified by the engine</strong> — the producer refuses to file a reaction under a family it does not
    actually belong to — and the net-ionic view strips spectators to the essential change. The
    <em>redox</em> tag is machine-derived: an element that appears free on one side and combined on the other
    changed oxidation state, so electrons moved.</p>

  <nav class="jump">
    {families.map((f) => <a href={`#${f.id}`}>{f.title}</a>)}
  </nav>

  {families.map((f) => (
    <article class="family" id={f.id}>
      <div class="f-head">
        <h2>{f.title}</h2>
        <span class="badges">
          <span class="badge sourced"><span class="dot"></span>rule-sourced ({f.source})</span>
          {f.redox === true && <span class="badge redox">redox</span>}
          {f.redox === false && <span class="badge notredox">not redox</span>}
          {f.redox === undefined && <span class="badge maybe">redox varies</span>}
        </span>
      </div>

      <div class="form">
        {f.general_formHtml ? <span set:html={f.general_formHtml} /> : <code>{f.general_formPretty}</code>}
      </div>
      <p class="summary">{f.summaryPretty}</p>

      {f.conditions.length > 0 && (
        <ul class="conditions">{f.conditions.map((c) => <li>{c}</li>)}</ul>
      )}

      <h3 class="lbl">Verified examples</h3>
      <div class="examples">
        {f.examples.map((ex) => (
          <div class="example">
            <div class="eq" set:html={ex.equationHtml} />
            {ex.netHtml && (
              <div class="net">
                <span class="net-lbl">net ionic</span>
                <span class="net-eq" set:html={ex.netHtml} />
              </div>
            )}
            <p class="evidence">{ex.evidencePretty}</p>
            {ex.redox && ex.redoxReasonPretty && (
              <p class="redox-note"><span class="chip">redox</span>{ex.redoxReasonPretty}</p>
            )}
            {ex.spectatorsPretty.length > 0 && (
              <p class="spectators">Spectators: {ex.spectatorsPretty.map((s, i) => (
                <>{i > 0 && ", "}<span class="ion">{s}</span></>
              ))}</p>
            )}
          </div>
        ))}
      </div>

      <h3 class="lbl">Watch out for</h3>
      <ul class="misconceptions">
        {f.misconceptions.map((m) => (
          <li><span class="claim">{m.claim}</span> <span class="refute">{m.refute}</span></li>
        ))}
      </ul>

      {(f.related.length > 0 || f.lessons.length > 0) && (
        <div class="links">
          {f.related.length > 0 && (
            <span class="ln">Related: {f.related.map((e, i) => (
              <>{i > 0 && ", "}<a href={withBase(`/reference/#${e.to}`)}>{conceptTitle[e.to] ?? e.to}</a>
                <span class="etype"> ({e.type})</span></>
            ))}</span>
          )}
          {f.lessons.length > 0 && (
            <span class="ln">Lessons: {f.lessons.map((s, i) => (
              <>{i > 0 && ", "}<a href={withBase(`/lessons/${s}/`)}>{lessonTitle[s] ?? s}</a></>
            ))}</span>
          )}
        </div>
      )}
    </article>
  ))}

  <style>
    .crumb { font-size: 0.9rem; margin: 0 0 0.4rem; }
    h1 { font-size: 1.9rem; margin-bottom: 0.3rem; }
    .lede { max-width: 50rem; }
    .jump { display: flex; flex-wrap: wrap; gap: 0.4rem 0.8rem; margin: 1rem 0 1.6rem; font-size: 0.9rem; }
    .jump a { padding: 0.15rem 0.6rem; background: var(--paper-2); border: 1px solid var(--line); border-radius: 999px; }
    .jump a:hover { border-color: var(--accent); text-decoration: none; }
    .family { background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.1rem 1.3rem; margin: 1.1rem 0; scroll-margin-top: 5rem; }
    .f-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .f-head h2 { margin: 0; font-size: 1.3rem; color: var(--accent); }
    .badges { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .form { margin: 0.6rem 0 0.3rem; font-size: 1.05rem; overflow-x: auto; }
    .form code { background: var(--paper); padding: 0.15rem 0.45rem; border-radius: 6px; font-size: 0.95rem; }
    .summary { color: var(--ink-2); margin: 0.3rem 0 0.6rem; max-width: 54rem; }
    .conditions { color: var(--ink-faint); font-size: 0.88rem; margin: 0 0 0.4rem; padding-left: 1.1rem; }
    .conditions li { margin: 0.15rem 0; }
    .lbl { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-faint); margin: 1rem 0 0.5rem; border-bottom: 1px solid var(--line); padding-bottom: 0.2rem; }
    .examples { display: grid; gap: 0.7rem; }
    .example { background: var(--paper); border: 1px solid var(--line); border-radius: 8px; padding: 0.7rem 0.9rem; }
    .eq { font-size: 1.05rem; overflow-x: auto; }
    .net { display: flex; align-items: baseline; gap: 0.5rem; margin-top: 0.35rem; overflow-x: auto; }
    .net-lbl { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--accent); flex-shrink: 0; }
    .evidence { color: var(--ink-2); font-size: 0.9rem; margin: 0.5rem 0 0; }
    .redox-note { color: var(--ink-faint); font-size: 0.84rem; margin: 0.35rem 0 0; }
    .chip { display: inline-block; background: var(--amber-bg, #f5e6c8); color: var(--amber-ink, #7a5b12); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em; padding: 0.05rem 0.4rem; border-radius: 4px; margin-right: 0.4rem; }
    .spectators { font-size: 0.84rem; color: var(--ink-faint); margin: 0.35rem 0 0; }
    .ion { font-variant-numeric: normal; }
    .misconceptions { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem; }
    .misconceptions li { border-left: 3px solid var(--line); padding-left: 0.7rem; }
    .claim { color: var(--ink-2); font-style: italic; }
    .claim::before { content: "✗ "; color: #b4442f; font-style: normal; }
    .refute { color: var(--ink-2); display: block; margin-top: 0.15rem; }
    .refute::before { content: "→ "; color: var(--accent); }
    .links { display: flex; flex-wrap: wrap; gap: 0.3rem 1.2rem; font-size: 0.86rem; color: var(--ink-faint); margin-top: 0.8rem; border-top: 1px solid var(--line); padding-top: 0.5rem; }
    .etype { font-style: italic; }
    .badge.redox { background: #e9dcc3; color: #7a5b12; }
    .badge.notredox { background: var(--paper); color: var(--ink-faint); border: 1px solid var(--line); }
    .badge.maybe { background: var(--paper); color: var(--ink-faint); border: 1px dashed var(--line); }
  </style>
</Base>
