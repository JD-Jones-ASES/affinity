---
import Base from "../../layouts/Base.astro";
import DimensionalGym from "../../islands/DimensionalGym.svelte";
import { withBase } from "../../lib/withBase.js";
import { renderGym } from "../../lib/view.js";

// One page per committed gym (ADR-0024). The producer is the source of truth; this page renders it — no
// chemistry happens here. The only view transform is typography: renderGym subscripts the substance tokens.
export function getStaticPaths() {
  const all = import.meta.glob("../../../derived/gyms/*.gym.json", { eager: true });
  return Object.values(all).map((m) => ({ params: { slug: m.default.slug }, props: { gym: m.default } }));
}

const { gym: gymRaw } = Astro.props;
const gym = renderGym(gymRaw);   // build-time view prep: Unicode subscripts in prompts/explanations

// Concept chips → the Atlas, mirroring the lesson page.
const refs = import.meta.glob("../../../derived/reference/*.json", { eager: true });
const conceptIds = new Set(Object.values(refs).map((m) => m.default).filter((r) => r.kind === "concept").map((r) => r.id));
const valenceTopics = new Set(["calcium", "carbonate", "sodium", "chloride", "chlorine", "sulfate", "nitrate", "phosphate", "acetate", "ammonium", "hydroxide", "oxide"]);
const conceptLabel = (id) => id.split("-").map((w) => w[0].toUpperCase() + w.slice(1)).join(" ");
const concepts = (gym.reference_links ?? []).map((id) => ({
  id,
  label: conceptLabel(id),
  href: conceptIds.has(id) ? withBase(`/reference/#${id}`) : valenceTopics.has(id) ? withBase("/reference/valence-table/") : null,
}));
// the sourced-data badge names what the family actually drills: the periodic-trends gym embeds sourced
// properties/charges (ADR-0034); every other family rests on the sourced molar masses.
const trendSources = gym.provenance?.sources ?? {};
const isTrends = gym.family === "periodic_trends_v1";
const sourceLabel = isTrends
  ? `properties sourced (${[trendSources.electronegativity, trendSources.covalent_radius, trendSources.ionization_energy].filter(Boolean).join(", ")})`
  : `molar masses sourced (${trendSources.atomic_weight})`;
const source = isTrends ? trendSources.ionization_energy : trendSources.atomic_weight;
---

<Base title={`${gym.title} — Affinity`} description={gym.blurb}>
  <p class="crumb faint"><a href={withBase("/gym/")}>Gym</a> · {gym.topic}</p>
  <h1>{gym.title}</h1>
  <p class="muted lede">{gym.blurb}</p>
  <div class="badges">
    <span class="badge machine"><span class="dot"></span>{gym.problems.length} machine-verified problems</span>
    {source && <span class="badge sourced"><span class="dot"></span>{sourceLabel}</span>}
  </div>

  <DimensionalGym gym={gym} client:load />

  <section class="links">
    <h2>Concepts in this gym</h2>
    <ul class="chips">
      {concepts.map((c) => (
        <li class="chip">{c.href ? <a href={c.href}>{c.label}</a> : c.label}</li>
      ))}
    </ul>
  </section>

  <style>
    h1 { font-size: 1.9rem; }
    .crumb { margin-bottom: 0.3rem; }
    .lede { max-width: 48rem; }
    .badges { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 0.6rem 0 1.2rem; }
    .links { margin-top: 2.5rem; }
    .chips { list-style: none; padding: 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .chip { background: var(--paper-sunk); color: var(--ink-2); padding: 0.25rem 0.65rem; border-radius: 999px; font-size: 0.85rem; }
  </style>
</Base>
