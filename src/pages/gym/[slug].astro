---
import Base from "../../layouts/Base.astro";
import DimensionalGym from "../../islands/DimensionalGym.svelte";
import { withBase } from "../../lib/withBase.js";
import { renderGym } from "../../lib/view.js";
import { gymLessons } from "../../lib/curriculum.js";

// One page per committed gym (ADR-0024). The producer is the source of truth; this page renders it — no
// chemistry happens here. The only view transform is typography: renderGym subscripts the substance tokens.
export function getStaticPaths() {
  const all = import.meta.glob("../../../derived/gyms/*.gym.json", { eager: true });
  return Object.values(all).map((m) => ({ params: { slug: m.default.slug }, props: { gym: m.default } }));
}

const { gym: gymRaw } = Astro.props;
const gym = renderGym(gymRaw);   // build-time view prep: Unicode subscripts in prompts/explanations

// Concept chips → the Atlas, mirroring the lesson page. Concept ids link to /reference/#id; reaction-family
// ids (ADR-0035) → /reference/reactions/#id; formula ids (ADR-0039/0040) → /reference/formulas/#id.
const refs = import.meta.glob("../../../derived/reference/*.json", { eager: true });
const refObjs = Object.values(refs).map((m) => m.default);
const conceptIds = new Set(refObjs.filter((r) => r.kind === "concept").map((r) => r.id));
const familyIds = new Set(refObjs.filter((r) => r.kind === "reaction-family").map((r) => r.id));
const formulaIds = new Set(refObjs.filter((r) => r.kind === "formula").map((r) => r.id));
const refTitle = Object.fromEntries(refObjs.map((r) => [r.id, r.title]));
const valenceTopics = new Set(["calcium", "carbonate", "sodium", "chloride", "chlorine", "sulfate", "nitrate", "phosphate", "acetate", "ammonium", "hydroxide", "oxide"]);
const conceptLabel = (id) => refTitle[id] ?? id.replace(/^(reaction|formula)-/, "").split("-").map((w) => w[0].toUpperCase() + w.slice(1)).join(" ");
const concepts = (gym.reference_links ?? []).map((id) => ({
  id,
  label: conceptLabel(id),
  href: conceptIds.has(id) ? withBase(`/reference/#${id}`)
    : familyIds.has(id) ? withBase(`/reference/reactions/#${id}`)
    : formulaIds.has(id) ? withBase(`/reference/formulas/#${id}`)
    : valenceTopics.has(id) ? withBase("/reference/valence-table/") : null,
}));
// the sourced-data badge names what the family actually drills: the periodic-trends gym embeds sourced
// properties/charges (ADR-0034); the reaction-families gym rests on the sourced classification data
// (ADR-0035); the gas-laws gym on the sourced gas constant (ADR-0040); the calorimetry gym on the sourced
// specific heats (ADR-0042); every other family on sourced molar masses.
const gymSources = gym.provenance?.sources ?? {};

// Related-lesson cross-links (QC 2026-07-09 C1): the lessons this gym drills, from the curriculum map. Titles
// come from the lesson JSON across all seven kinds.
const lessonMods = {
  ...import.meta.glob("../../../derived/**/*.solution.json", { eager: true }),
  ...import.meta.glob("../../../derived/**/*.structure.json", { eager: true }),
  ...import.meta.glob("../../../derived/**/*.comparison.json", { eager: true }),
  ...import.meta.glob("../../../derived/**/*.equilibrium.json", { eager: true }),
  ...import.meta.glob("../../../derived/**/*.prediction.json", { eager: true }),
  ...import.meta.glob("../../../derived/**/*.kinetics.json", { eager: true }),
  ...import.meta.glob("../../../derived/**/*.electrochemistry.json", { eager: true }),
};
const lessonTitle = Object.fromEntries(Object.values(lessonMods).map((m) => [m.default.slug, m.default.title]));
const relatedLessons = (gymLessons[gym.slug] ?? []).map((slug) => ({ slug, title: lessonTitle[slug] ?? slug }));

const isTrends = gym.family === "periodic_trends_v1";
const isFamilies = gym.family === "reaction_families_v1";
const isGas = gym.family === "gas_laws_v1";
const isCalor = gym.family === "calorimetry_v1";
const isLewis = gym.family === "lewis_structures_v1";
const sourceLabel = isTrends
  ? `properties sourced (${[gymSources.electronegativity, gymSources.covalent_radius, gymSources.ionization_energy].filter(Boolean).join(", ")})`
  : isFamilies
  ? `reaction classes sourced (${gymSources.reaction_classes})`
  : isGas
  ? `gas constant sourced (${gymSources.constants})`
  : isCalor
  ? `specific heats sourced (${gymSources.specific_heats})`
  : isLewis
  ? `group positions + VSEPR sourced (${[gymSources.position, gymSources.vsepr].filter(Boolean).join(", ")})`
  : `molar masses sourced (${gymSources.atomic_weight})`;
const source = isTrends ? gymSources.ionization_energy : isFamilies ? gymSources.reaction_classes : isGas ? gymSources.constants : isCalor ? gymSources.specific_heats : isLewis ? gymSources.vsepr : gymSources.atomic_weight;
// a regime-2 gym discloses its model assumption under the model-assumed (amber) badge (ADR-0040)
const assumptions = gym.assumptions ?? [];
---

<Base title={`${gym.title} — Affinity`} description={gym.blurb}>
  <p class="crumb faint"><a href={withBase("/gym/")}>Gym</a> · {gym.topic}</p>
  <h1>{gym.title}</h1>
  <p class="muted lede">{gym.blurb}</p>
  <div class="badges">
    <span class="badge machine"><span class="dot"></span>{gym.problems.length} machine-verified problems</span>
    {source && <span class="badge sourced"><span class="dot"></span>{sourceLabel}</span>}
    {assumptions.length > 0 && <span class="badge model"><span class="dot"></span>model-assumed</span>}
  </div>

  {assumptions.length > 0 && (
    <p class="assume">
      <strong>Model:</strong> {assumptions.map((a) => a.claim).join(" ")} The arithmetic is machine-checked and
      the answer is reported to 3 significant figures.
    </p>
  )}

  <DimensionalGym gym={gym} client:load />

  <section class="links">
    <h2>Concepts in this gym</h2>
    <ul class="chips">
      {concepts.map((c) => (
        <li class="chip">{c.href ? <a href={c.href}>{c.label}</a> : c.label}</li>
      ))}
    </ul>
  </section>

  {relatedLessons.length > 0 && (
    <section class="practice">
      <h2>Lessons that use this</h2>
      <p class="muted">See these skills worked in depth on a single scenario:</p>
      <ul class="gymlinks">
        {relatedLessons.map((l) => (
          <li><a href={withBase(`/lessons/${l.slug}/`)}>{l.title} →</a></li>
        ))}
      </ul>
    </section>
  )}

  <style>
    h1 { font-size: 1.9rem; }
    .crumb { margin-bottom: 0.3rem; }
    .lede { max-width: 48rem; }
    .badges { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 0.6rem 0 1.2rem; }
    .assume { max-width: 48rem; font-size: 0.9rem; color: var(--ink-2); background: var(--paper-2); border: 1px solid var(--line); border-left: 3px solid var(--badge-model, #b8860b); border-radius: 6px; padding: 0.6rem 0.85rem; margin: 0 0 1.2rem; }
    .links { margin-top: 2.5rem; }
    .practice { margin-top: 1.8rem; }
    .practice h2 { font-size: 1.15rem; }
    .gymlinks { list-style: none; padding: 0; display: grid; gap: 0.5rem; }
    .gymlinks a { display: block; background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 0.6rem 0.9rem; color: var(--accent); font-weight: 600; }
    .gymlinks a:hover { text-decoration: none; border-color: var(--accent); }
    .chips { list-style: none; padding: 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .chip { background: var(--paper-sunk); color: var(--ink-2); padding: 0.25rem 0.65rem; border-radius: 999px; font-size: 0.85rem; }
  </style>
</Base>
