---
import "@fontsource-variable/space-grotesk";
import "@fontsource/ibm-plex-mono";
import "katex/dist/katex.min.css";
import "../styles/portal.css";
import { withBase } from "../lib/withBase.js";

const {
  title = "Affinity",
  description = "A beginning-chemistry course where the verification system is the product — every claim machine-checked, sourced, or disclosed.",
} = Astro.props;
const nav = [
  ["Home", "/"],
  ["Lessons", "/lessons/"],
  ["Gym", "/gym/"],
  ["Reference", "/reference/"],
  ["Verification", "/verification/"],
];
// Self-contained SVG favicon: the brand "A" (accent blue on paper), inline as a data URI — no external asset,
// no base-path concern (data URIs need no withBase). Matches the header wordmark's accent "A".
const favicon = "data:image/svg+xml," + encodeURIComponent(
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><rect width="32" height="32" rx="7" fill="#2f6f9f"/><path d="M16 7 L24 26 M16 7 L8 26 M11.2 20 H20.8" fill="none" stroke="#fbfaf7" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>'
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={favicon} />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={withBase("/")}><span class="a">A</span>ffinity</a>
        <nav class="nav">
          {nav.map(([label, href]) => <a href={withBase(href)}>{label}</a>)}
        </nav>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="wrap">
        Beginning chemistry, verified by ChemKernel at build time. Code MIT · content CC BY-SA 4.0.
        AI-authored under an owner-designed verification system — the system is the safeguard.
      </div>
    </footer>
  </body>
</html>
