  "scenario": "A burner burns 0.80215 g of methane (CH₄) in 3.83976 g of oxygen. The reaction goes to completion, and the heat released is measured. Which reactant runs out first, and how much heat does this burn actually release?",
  "regimes": [
    {
      "facet": "ledger",
      "regime": "ledger-exact"
    },
    {
      "facet": "thermochemistry",
      "regime": "model-exact"
    }
  ],
  "assumptions": [
    {
      "claim": "The combustion goes to completion — every mole of the limiting reagent that can react, does.",
      "kind": "model"
    },
    {
      "claim": "Enthalpy is a state function, so ΔH_rxn depends only on the substances, not the path — this is Hess's law, and it lets ΔH_rxn be built from standard enthalpies of formation.",
      "kind": "model"
    },
    {
      "claim": "The standard enthalpies of formation apply at these conditions (298.15 K, constant pressure) and are treated as temperature-independent over the range.",
      "kind": "model"
    },
    {
      "claim": "The water product is liquid (its ΔH_f° = −285.83 kJ/mol); if it left as vapor the reaction would release less heat.",
      "kind": "model"
    }
  ],
  "given": [
    {
      "species": "CH4(g)",
      "mass_g": "0.80215",
      "moles": "0.05"
    },
    {
      "species": "O2(g)",
      "mass_g": "3.83976",
      "moles": "0.12"
