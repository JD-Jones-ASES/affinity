  "blurb": "Endless generated quantity-algebra where the units do the bookkeeping. Convert between volume, molarity, moles, and mass — one conversion factor at a time — and watch the units cancel down the chain. Type your answer: every value is machine-computed, and if your entry matches a known cancellation mistake it is named, not just marked wrong.",
  "skills": [
    "mL → L (÷ 1000)",
    "volume × molarity → moles",
    "moles ÷ molarity → volume",
    "mass ↔ moles via molar mass",
    "volume + molarity + molar mass → grams"
  ],
  "reference_links": [
    "dimensional-analysis",
    "molarity",
    "molar-mass"
  ],
  "problems": [
    {
      "kind": "volume_molarity_to_moles",
      "mode": "numeric",
      "prompt": "How many moles of CaCl2 are in 50 mL of 0.2 M CaCl2(aq)?",
      "chain": [
        {
          "value": "50",
          "unit": "mL",
          "note": "given volume"
        },
        {
          "value": "0.05",
          "unit": "L",
          "note": "× (1 L / 1000 mL)"
        },
        {
          "value": "0.01",
          "unit": "mol",
          "note": "× 0.2 mol/L"
        }
      ],
      "target_unit": "mol",
      "answer": {
        "value": "0.01",
        "unit": "mol",
        "display": "0.01 mol"
      },
      "derivation": {
        "kind": "volume_molarity_to_moles",
        "inputs": {
          "substance": "CaCl2",
          "v_mL": "50",
          "c_M": "0.2"
        }
      },
      "diagnostics": [
        {
          "value": "10",
          "unit": "mol",
          "misconception": "Skipped mL → L — the volume must be in litres before multiplying by mol/L (a factor of 1000)."
        },
        {
          "value": "0.25",
          "unit": "mol",
          "misconception": "Divided the volume by the molarity; the factor is × mol/L, and L × mol/L = mol."
        }
      ],
      "explain": "50 mL = 0.05 L; × 0.2 mol/L = 0.01 mol. The litres cancel against mol/L, leaving mol.",
      "id": "q1"
    },
