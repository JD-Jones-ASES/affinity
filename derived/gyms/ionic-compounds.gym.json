{
  "kind": "gym",
  "id": "nomenclature-ionic-compounds",
  "title": "Naming ionic compounds: formula ↔ name",
  "slug": "ionic-compounds",
  "topic": "nomenclature",
  "family": "ionic_nomenclature_v1",
  "seed": 8175003,
  "blurb": "Name an ionic compound from its formula, and write the formula from the name — both directions, including the Stock system (iron(III), copper(I)) for variable-charge metals. The formula is assembled by machine-verified charge crossover; every wrong option is a specific naming mistake (wrong oxidation state, charges used as subscripts, or covalent prefixes on an ionic compound).",
  "skills": [
    "cation name + anion (-ide / -ate) name",
    "Stock Roman numerals for variable-charge metals",
    "charge crossover: each subscript is the other ion's charge",
    "polyatomic ions kept as a unit with parentheses"
  ],
  "reference_links": [
    "nomenclature",
    "polyatomic-ion",
    "dimensional-analysis"
  ],
  "problems": [
    {
      "kind": "ionic_formula_to_name",
      "prompt": "What is the name of NaNO3?",
      "answer": {
        "value": "sodium nitrate",
        "display": "sodium nitrate"
      },
      "derivation": {
        "kind": "ionic_formula_to_name",
        "cation": {
          "id": "Na^+",
          "formula_part": "Na",
          "charge": 1,
          "compound_name": "sodium"
        },
        "anion": {
          "id": "NO3^-",
          "formula_part": "NO3",
          "charge": -1,
          "compound_name": "nitrate"
        },
        "formula": "NaNO3",
        "name": "sodium nitrate"
      },
      "choices": [
        {
          "display": "sodium nitrate",
          "correct": true,
          "misconception": null
        },
        {
          "display": "sodium(I) nitrate",
          "correct": false,
          "misconception": "Added a Roman numeral to a fixed-charge metal — only variable-charge metals take one."
        },
        {
          "display": "monosodium mononitrate",
          "correct": false,
          "misconception": "Used Greek prefixes (mono-, di-, tri-) — those name covalent molecules, not ionic compounds."
        }
      ],
      "explain": "Na^+ is the cation and NO3^- the anion; a fixed-charge metal needs no numeral, so NaNO3 is sodium nitrate.",
      "subscript_tokens": [
        "NaNO3",
        "Na^+",
        "NO3^-"
      ],
      "id": "q1"
    },
    {
      "kind": "ionic_name_to_formula",
      "prompt": "Write the formula for magnesium hydroxide.",
      "answer": {
        "value": "Mg(OH)2",
        "display": "Mg(OH)2"
      },
      "derivation": {
        "kind": "ionic_name_to_formula",
        "cation": {
          "id": "Mg^2+",
          "formula_part": "Mg",
          "charge": 2,
          "compound_name": "magnesium"
        },
        "anion": {
          "id": "OH^-",
          "formula_part": "OH",
          "charge": -1,
          "compound_name": "hydroxide"
        },
        "formula": "Mg(OH)2",
        "name": "magnesium hydroxide"
      },
      "choices": [
        {
          "display": "Mg(OH)2",
          "correct": true,
          "misconception": null
        },
        {
          "display": "Mg2OH",
          "correct": false,
          "misconception": "Used each ion's own charge as its subscript — you CROSS the charges (each subscript is the other ion's charge)."
        },
        {
          "display": "MgOH",
          "correct": false,
          "misconception": "Combined one-to-one — the charges (+2, −1) don't cancel one-for-one; balance them."
        }
      ],
      "explain": "Mg^2+ and OH^- cross their charges: 1×Mg to 2×(hydroxide) gives the neutral Mg(OH)2.",
      "subscript_tokens": [
        "Mg(OH)2",
        "Mg2OH",
        "MgOH",
        "Mg^2+",
        "OH^-"
      ],
      "id": "q2"
    },
