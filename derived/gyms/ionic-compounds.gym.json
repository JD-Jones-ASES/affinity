{
  "kind": "gym",
  "id": "nomenclature-ionic-compounds",
  "title": "Naming ionic compounds: formula ↔ name",
  "slug": "ionic-compounds",
  "topic": "nomenclature",
  "family": "ionic_nomenclature_v1",
  "seed": 8175003,
  "blurb": "Name an ionic compound from its formula, and write the formula from the name — both directions, including the Stock system (iron(III), copper(I)) for variable-charge metals. The formula is assembled by machine-verified charge crossover; every wrong option is a specific naming mistake (wrong oxidation state, charges used as subscripts, or covalent prefixes on an ionic compound).",
  "skills": [
    "cation name + anion (-ide / -ate) name",
    "Stock Roman numerals for variable-charge metals",
    "charge crossover: each subscript is the other ion's charge",
    "polyatomic ions kept as a unit with parentheses"
  ],
  "reference_links": [
    "nomenclature",
    "polyatomic-ion",
    "dimensional-analysis"
  ],
  "problems": [
    {
      "kind": "ionic_formula_to_name",
      "mode": "choice",
      "prompt": "What is the name of Mg(HCO3)2?",
      "answer": {
        "value": "magnesium hydrogen carbonate",
        "display": "magnesium hydrogen carbonate"
      },
      "derivation": {
        "kind": "ionic_formula_to_name",
        "cation": {
          "id": "Mg^2+",
          "formula_part": "Mg",
          "charge": 2,
          "compound_name": "magnesium"
        },
        "anion": {
          "id": "HCO3^-",
          "formula_part": "HCO3",
          "charge": -1,
          "compound_name": "hydrogen carbonate"
        },
        "formula": "Mg(HCO3)2",
        "name": "magnesium hydrogen carbonate"
      },
      "choices": [
        {
          "display": "magnesium hydrogen carbonate",
          "correct": true,
          "misconception": null
        },
        {
          "display": "magnesium(II) hydrogen carbonate",
          "correct": false,
          "misconception": "Added a Roman numeral to a fixed-charge metal — only variable-charge metals take one."
        },
        {
          "display": "monomagnesium dihydrogen carbonate",
          "correct": false,
          "misconception": "Used Greek prefixes (mono-, di-, tri-) — those name covalent molecules, not ionic compounds."
        }
      ],
      "explain": "Mg^2+ is the cation and HCO3^- the anion; a fixed-charge metal needs no numeral, so Mg(HCO3)2 is magnesium hydrogen carbonate.",
      "subscript_tokens": [
        "Mg(HCO3)2",
        "Mg^2+",
        "HCO3^-"
      ],
      "id": "q1"
    },
    {
      "kind": "ionic_name_to_formula",
      "mode": "choice",
      "prompt": "Write the formula for potassium nitride.",
      "answer": {
        "value": "K3N",
        "display": "K3N"
      },
      "derivation": {
        "kind": "ionic_name_to_formula",
        "cation": {
          "id": "K^+",
          "formula_part": "K",
          "charge": 1,
          "compound_name": "potassium"
        },
        "anion": {
          "id": "N^3-",
          "formula_part": "N",
          "charge": -3,
          "compound_name": "nitride"
        },
        "formula": "K3N",
        "name": "potassium nitride"
      },
      "choices": [
        {
          "display": "K3N",
          "correct": true,
          "misconception": null
        },
        {
          "display": "KN3",
          "correct": false,
          "misconception": "Used each ion's own charge as its subscript — you CROSS the charges (each subscript is the other ion's charge)."
        },
        {
          "display": "KN",
          "correct": false,
          "misconception": "Combined one-to-one — the charges (+1, −3) don't cancel one-for-one; balance them."
        }
      ],
      "explain": "K^+ and N^3- cross their charges: 3×K to 1×(nitride) gives the neutral K3N.",
      "subscript_tokens": [
        "K3N",
        "KN3",
        "KN",
        "K^+",
        "N^3-"
      ],
      "id": "q2"
    },
