  "assumptions": [
    {
      "claim": "The solution has reached equilibrium, and this single ionization is the only reaction that matters (one dominant equilibrium).",
      "kind": "model"
    },
    {
      "claim": "Activities are approximated by molar concentrations — the ideal-dilute-solution model, which is why $K_a$ is written with concentrations.",
      "kind": "model"
    },
    {
      "claim": "The $\\mathrm{H^+}$ from water's own autoionization ($10^{-7}\\,\\text{M}$) is negligible beside the acid's, so $[\\mathrm{H^+}]_0 = 0$ in the table.",
      "kind": "model"
    }
  ],
