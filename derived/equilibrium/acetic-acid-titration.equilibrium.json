      "facet": "titration curve (pH vs added base)",
      "regime": "model-exact"
    }
  ],
  "assumptions": [
    {
      "claim": "Each region is solved by the dominant equilibrium — the weak acid / buffer before equivalence, the conjugate base's hydrolysis at equivalence, excess $\\mathrm{OH^-}$ after — the standard treatment; the strong base is taken as fully dissociated, so the added $\\mathrm{OH^-}$ moles are exact.",
      "kind": "model"
    },
    {
      "claim": "Volumes are additive (the total is the acid volume plus the added titrant volume), and activities are approximated by molar concentrations — the ideal-dilute-solution model.",
      "kind": "model"
    }
  ],
