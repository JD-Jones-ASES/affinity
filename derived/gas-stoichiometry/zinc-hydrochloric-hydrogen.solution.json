  "scenario": "A 3.269 g strip of zinc metal is dropped into 120.0 mL of 1.00 M hydrochloric acid. The zinc dissolves, bubbling hydrogen gas, which is collected at 1.00 atm and 25.00 °C. Which reactant runs out first, and what volume of hydrogen forms?",
  "regimes": [
    {
      "facet": "ledger",
      "regime": "ledger-exact"
    },
    {
      "facet": "gas_behavior",
      "regime": "model-exact"
    }
  ],
  "assumptions": [
    {
      "claim": "The zinc reacts completely with the acid — the single-replacement reaction goes essentially to completion.",
      "kind": "model"
    },
    {
      "claim": "Hydrogen behaves as an ideal gas: PV = nRT holds exactly only for a dilute gas (low pressure, not-too-low temperature).",
      "kind": "model"
    },
    {
      "claim": "HCl is a strong acid and dissociates completely in water.",
      "kind": "model"
    },
    {
      "claim": "The hydrogen is collected dry at the stated pressure and temperature — no water-vapor-pressure correction (collecting a gas over water is a later refinement).",
      "kind": "model"
    }
  ],
  "given": [
    {
      "species": "Zn(s)",
      "mass_g": "3.269",
      "moles": "0.05"
    },
    {
      "species": "HCl(aq)",
