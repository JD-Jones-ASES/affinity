  "assumptions": [
    {
      "claim": "The gas is ideal: its particles have negligible volume and no intermolecular forces.",
      "kind": "model"
    },
    {
      "claim": "T is the absolute (kelvin) temperature — convert from °C by adding 273.15 before using the law.",
      "kind": "model"
    }
