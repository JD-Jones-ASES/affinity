{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affinity/schemas/electrochemistry-lesson.schema.json",
  "title": "Affinity electrochemistry lesson",
  "description": "One verified galvanic-cell lesson (ADR-0050): the species ledger with ELECTRONS as the tracked quantity — electron bookkeeping plus free energy per charge. A redox reaction moves n moles of electrons from the species oxidized (anode) to the species reduced (cathode); E°cell = E°(cathode) − E°(anode) reads off the sourced standard reduction potentials, and ΔG° = −nFE°. Honesty is layered (the three badges): the oxidation-number + electron ledger is machine-checked (regime-1), E° is sourced (regime-3), the cell potential + free energy ride the standard-state model (regime-2, model-exact-then-rounded). A distinct, tight schema (the 7th lesson shape). additionalProperties:false everywhere.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind", "subtype", "id", "title", "slug", "topic", "scenario", "regimes", "assumptions",
    "reaction", "oxidation_states", "half_reactions", "electron_ledger", "cell", "result",
    "misconception", "checks", "provenance"
  ],
  "$defs": {
    "decimalString": { "type": "string", "pattern": "^[+-]?(?:[0-9]+\\.?[0-9]*|\\.[0-9]+)$" },
    "halfReaction": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "couple_name", "equation_latex", "electrons", "multiplier", "e_standard_V", "e_standard_display", "element", "ox_from", "ox_to"],
      "properties": {
        "role": { "enum": ["anode", "cathode"] },
        "couple_name": { "type": "string", "minLength": 1 },
        "equation_latex": { "type": "string", "minLength": 1 },
        "electrons": { "type": "integer", "minimum": 1 },
        "multiplier": { "type": "integer", "minimum": 1 },
        "e_standard_V": { "$ref": "#/$defs/decimalString" },
        "e_standard_display": { "$ref": "#/$defs/decimalString" },
        "element": { "type": "string", "pattern": "^[A-Z][a-z]?$" },
        "ox_from": { "type": "string", "minLength": 1 },
        "ox_to": { "type": "string", "minLength": 1 }
      }
    }
  },
  "properties": {
    "kind": { "const": "electrochemistry" },
    "subtype": { "enum": ["galvanic"], "$comment": "galvanic for now; electrolytic / nonstandard (Nernst) can extend it" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "topic": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "scenario": { "type": "string", "minLength": 1 },
    "regimes": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false, "required": ["facet", "regime"],
        "properties": {
          "facet": { "type": "string" },
          "regime": { "enum": ["ledger-exact", "model-exact", "rule-sourced", "mechanistic"] }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false, "required": ["claim", "kind"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["model", "rule"] }
        }
      }
    },
    "reaction": {
      "type": "object", "additionalProperties": false,
      "required": ["equation_text", "equation_latex", "electrons_transferred"],
      "properties": {
        "equation_text": { "type": "string", "minLength": 1, "$comment": "house ASCII with -> ; balance re-checked by the gate" },
        "equation_latex": { "type": "string", "minLength": 1 },
        "electrons_transferred": { "type": "integer", "minimum": 1 }
      }
    },
    "oxidation_states": {
      "type": "object", "additionalProperties": false,
      "description": "Each species' per-atom oxidation numbers (summing to its charge, machine-checked), plus which element is oxidized / reduced and its before→after.",
      "required": ["species", "oxidized", "reduced"],
      "properties": {
        "species": {
          "type": "array", "minItems": 2,
          "items": {
            "type": "object", "additionalProperties": false, "required": ["formula", "latex", "atoms"],
            "properties": {
              "formula": { "type": "string", "minLength": 1 },
              "latex": { "type": "string", "minLength": 1 },
              "atoms": {
                "type": "array", "minItems": 1,
                "items": {
                  "type": "object", "additionalProperties": false, "required": ["element", "ox_number", "ox_display"],
                  "properties": {
                    "element": { "type": "string", "pattern": "^[A-Z][a-z]?$" },
                    "ox_number": { "type": "string", "minLength": 1, "$comment": "signed integer (or a/b for a mixed-valence average), e.g. '0', '2', '-2'" },
                    "ox_display": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        },
        "oxidized": { "$ref": "#/properties/oxidation_states/$defs/change" },
        "reduced": { "$ref": "#/properties/oxidation_states/$defs/change" }
      },
      "$defs": {
        "change": {
          "type": "object", "additionalProperties": false, "required": ["element", "from", "to"],
          "properties": {
            "element": { "type": "string", "pattern": "^[A-Z][a-z]?$" },
            "from": { "type": "string", "minLength": 1 },
            "to": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "half_reactions": {
      "type": "object", "additionalProperties": false,
      "required": ["oxidation", "reduction"],
      "properties": {
        "oxidation": { "$ref": "#/$defs/halfReaction" },
        "reduction": { "$ref": "#/$defs/halfReaction" }
      }
    },
    "electron_ledger": {
      "type": "object", "additionalProperties": false,
      "description": "n = the electrons transferred (lcm of the two half-reaction electron counts); the gate re-checks they cancel.",
      "required": ["n", "balanced", "note"],
      "properties": {
        "n": { "type": "integer", "minimum": 1 },
        "balanced": { "const": true },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "cell": {
      "type": "object", "additionalProperties": false,
      "required": ["anode_ion", "anode_metal", "anode_name", "cathode_ion", "cathode_metal", "cathode_name", "notation_text", "notation_latex", "e_cell_V", "e_cell_display", "spontaneous"],
      "properties": {
        "anode_ion": { "type": "string", "minLength": 1 },
        "anode_metal": { "type": "string", "minLength": 1 },
        "anode_name": { "type": "string", "minLength": 1 },
        "cathode_ion": { "type": "string", "minLength": 1 },
        "cathode_metal": { "type": "string", "minLength": 1 },
        "cathode_name": { "type": "string", "minLength": 1 },
        "notation_text": { "type": "string", "minLength": 1 },
        "notation_latex": { "type": "string", "minLength": 1 },
        "e_cell_V": { "$ref": "#/$defs/decimalString" },
        "e_cell_display": { "$ref": "#/$defs/decimalString" },
        "spontaneous": { "const": true }
      }
    },
    "result": {
      "type": "object", "additionalProperties": false,
      "description": "The headline: the cell potential E°cell, the electrons n, and the free energy ΔG° = −nFE° (spontaneous ⇔ E°cell > 0 ⇔ ΔG° < 0).",
      "required": ["e_cell_display", "e_cell_V", "n_electrons", "delta_g_kJ_per_mol", "delta_g_display", "faraday", "spontaneous"],
      "properties": {
        "e_cell_display": { "$ref": "#/$defs/decimalString" },
        "e_cell_V": { "$ref": "#/$defs/decimalString" },
        "n_electrons": { "type": "integer", "minimum": 1 },
        "delta_g_kJ_per_mol": { "$ref": "#/$defs/decimalString" },
        "delta_g_display": { "$ref": "#/$defs/decimalString" },
        "faraday": { "$ref": "#/$defs/decimalString" },
        "spontaneous": { "const": true }
      }
    },
    "misconception": {
      "type": "object", "additionalProperties": false, "required": ["claim", "refuted_by"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "refuted_by": { "type": "string" }
      }
    },
    "reference_links": { "type": "array", "items": { "type": "string" } },
    "checks": {
      "type": "object", "additionalProperties": false,
      "$comment": "the machine-checked facts, SHOWN not asserted. All const true — the producer refuses to emit otherwise (ADR-0008), and the gate re-derives each independently.",
      "required": ["oxidation_states_sum", "half_reactions_balanced", "electrons_cancel", "cell_potential", "delta_g_relation"],
      "properties": {
        "oxidation_states_sum": { "const": true },
        "half_reactions_balanced": { "const": true },
        "electrons_cancel": { "const": true },
        "cell_potential": { "const": true },
        "delta_g_relation": { "const": true }
      }
    },
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["producer", "version", "author", "created", "sources"],
      "properties": {
        "producer": { "const": "chemkernel" },
        "version": { "type": "string" },
        "python": { "type": "string" },
        "author": { "type": "string" },
        "created": { "type": "string" },
        "sources": {
          "type": "object", "additionalProperties": false,
          "required": ["reduction_potentials", "constants"],
          "properties": {
            "reduction_potentials": { "type": "string", "minLength": 1 },
            "constants": { "type": "string", "minLength": 1 },
            "atomic_weight": { "type": "string" }
          }
        }
      }
    }
  }
}
