{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affinity/schemas/equilibrium-lesson.schema.json",
  "title": "Affinity equilibrium lesson",
  "description": "One verified reversible-equilibrium lesson (ADR-0048): the species ledger with the extent solved from MASS ACTION rather than the limiting reagent. Where a solution.json (ADR-0020) runs a reaction to completion (ξ = the limiting-reagent minimum), an equilibrium lesson is the ICE table — every concentration c_i = c_{i,0} + ν_i·x, with x the root of Q(x)=K (chemkernel.equilibrium.solve_equilibrium). A distinct, tight schema keeps solution.schema.json pristine. additionalProperties:false everywhere.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind", "id", "title", "slug", "topic", "scenario", "regimes", "assumptions",
    "reaction", "equilibrium_constant", "ice", "mass_action", "result", "misconception", "checks", "provenance"
  ],
  "$defs": {
    "decimalString": { "type": "string", "pattern": "^[+-]?(?:[0-9]+\\.?[0-9]*|\\.[0-9]+)$" }
  },
  "properties": {
    "kind": { "const": "equilibrium" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "topic": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "scenario": { "type": "string", "minLength": 1 },
    "regimes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["facet", "regime"],
        "properties": {
          "facet": { "type": "string" },
          "regime": { "enum": ["ledger-exact", "model-exact", "rule-sourced", "mechanistic"] }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "kind"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["model", "rule"] }
        }
      }
    },
    "reaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acid", "acid_name", "acid_latex", "text", "latex", "conjugate_base"],
      "properties": {
        "acid": { "type": "string", "minLength": 1 },
        "acid_name": { "type": "string", "minLength": 1 },
        "acid_latex": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1, "$comment": "house ASCII with the <=> equilibrium arrow" },
        "latex": { "type": "string", "minLength": 1, "$comment": "\\rightleftharpoons for the equilibrium" },
        "conjugate_base": { "type": "string", "minLength": 1 }
      }
    },
    "equilibrium_constant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol", "value", "expression_latex", "source"],
      "properties": {
        "symbol": { "type": "string", "minLength": 1 },
        "value": { "$ref": "#/$defs/decimalString" },
        "expression_latex": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1, "$comment": "must resolve in docs/SOURCES.md (data-sourced badge)" }
      }
    },
    "ice": {
      "type": "object",
      "additionalProperties": false,
      "description": "The ICE table = the species ledger in concentrations. Every row's equilibrium_M = initial_M + ν·extent_M (the ledger identity, re-derived by the gate). extent_M is the solved reaction extent x (the value that satisfies mass action); it is model-exact-then-rounded (the root is generally irrational).",
      "required": ["extent_symbol", "extent_M", "extent_M_display", "species"],
      "properties": {
        "extent_symbol": { "type": "string", "minLength": 1 },
        "extent_M": { "$ref": "#/$defs/decimalString" },
        "extent_M_display": { "$ref": "#/$defs/decimalString" },
        "species": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "latex", "phase", "role", "nu", "initial_M", "change_M", "equilibrium_M", "equilibrium_M_display"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "latex": { "type": "string", "minLength": 1 },
              "phase": { "enum": ["s", "l", "g", "aq"] },
              "role": { "enum": ["reactant", "product"] },
              "nu": { "type": "integer", "not": { "const": 0 } },
              "initial_M": { "$ref": "#/$defs/decimalString" },
              "change_M": { "$ref": "#/$defs/decimalString" },
              "equilibrium_M": { "$ref": "#/$defs/decimalString" },
              "equilibrium_M_display": { "$ref": "#/$defs/decimalString" }
            }
          }
        }
      }
    },
    "mass_action": {
      "type": "object",
      "additionalProperties": false,
      "description": "The reaction quotient Q evaluated at the committed equilibrium concentrations, which reproduces K (the residual is the machine-check — the gate re-solves the root independently and re-checks Q=K).",
      "required": ["quotient_symbol", "quotient_at_equilibrium", "residual_relative"],
      "properties": {
        "quotient_symbol": { "type": "string", "minLength": 1 },
        "quotient_at_equilibrium": { "$ref": "#/$defs/decimalString" },
        "residual_relative": { "$ref": "#/$defs/decimalString" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hydronium_M", "hydronium_M_display", "pH", "pH_display", "percent_ionization", "percent_ionization_display"],
      "properties": {
        "hydronium_M": { "$ref": "#/$defs/decimalString" },
        "hydronium_M_display": { "$ref": "#/$defs/decimalString" },
        "pH": { "$ref": "#/$defs/decimalString" },
        "pH_display": { "$ref": "#/$defs/decimalString" },
        "percent_ionization": { "$ref": "#/$defs/decimalString" },
        "percent_ionization_display": { "$ref": "#/$defs/decimalString" }
      }
    },
    "misconception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "refuted_by"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "refuted_by": { "type": "string" }
      }
    },
    "reference_links": { "type": "array", "items": { "type": "string" } },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "the machine-checked facts, SHOWN not asserted. All const true — solve_equilibrium refuses to emit otherwise (ADR-0008).",
      "required": ["ice_identity", "mass_action_satisfied", "extent_physical", "ph_consistent"],
      "properties": {
        "ice_identity": { "const": true },
        "mass_action_satisfied": { "const": true },
        "extent_physical": { "const": true },
        "ph_consistent": { "const": true }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "version", "author", "created", "sources"],
      "properties": {
        "producer": { "const": "chemkernel" },
        "version": { "type": "string" },
        "python": { "type": "string" },
        "author": { "type": "string" },
        "created": { "type": "string" },
        "sources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ionization_constants", "ion_charge"],
          "properties": {
            "ionization_constants": { "type": "string", "minLength": 1 },
            "ion_charge": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
