{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affinity/schemas/equilibrium-lesson.schema.json",
  "title": "Affinity equilibrium lesson",
  "description": "One verified reversible-equilibrium lesson (ADR-0048): the species ledger with the extent solved from MASS ACTION rather than the limiting reagent. Where a solution.json (ADR-0020) runs a reaction to completion (ξ = the limiting-reagent minimum), an equilibrium lesson is the ICE table — every concentration c_i = c_{i,0} + ν_i·x, with x the root of Q(x)=K (chemkernel.equilibrium.solve_equilibrium). Four subtypes share this schema: `weak-acid` (HA ⇌ H⁺ + A⁻, the pH), `buffer` (the same reaction with A⁻ already present — the common-ion effect + Henderson–Hasselbalch), `weak-base` (B + H₂O ⇌ BH⁺ + OH⁻, → pOH → pH via K_w — water excluded from Q) `solubility` (a Ksp dissolution, the molar solubility — the pure solid excluded from Q; optionally with a **common ion** already present, which suppresses dissolution — the same nonzero-initial-product case the buffer proves, on the cubic), and `polyprotic` (a triprotic acid like H₃PO₄ ionizing in stages Kₐ1 ≫ Kₐ2 ≫ Kₐ3 — the top-level ice is the first, dominant ionization and result.later_stages carries the rest, each solved on the previous stage's outputs). A distinct, tight schema keeps solution.schema.json pristine. additionalProperties:false everywhere.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind", "subtype", "id", "title", "slug", "topic", "scenario", "regimes", "assumptions",
    "reaction", "equilibrium_constant", "ice", "mass_action", "result", "misconception", "checks", "provenance"
  ],
  "$defs": {
    "decimalString": { "type": "string", "pattern": "^[+-]?(?:[0-9]+\\.?[0-9]*|\\.[0-9]+)$" }
  },
  "properties": {
    "kind": { "const": "equilibrium" },
    "subtype": { "enum": ["weak-acid", "buffer", "weak-base", "solubility", "polyprotic"], "$comment": "discriminates the equilibrium shapes; the gate requires the subtype-specific reaction/result/checks fields. `polyprotic`: the top-level ice/mass_action/reaction/equilibrium_constant are the FIRST (dominant) ionization; result.later_stages carries stages 2..n" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "topic": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "scenario": { "type": "string", "minLength": 1 },
    "regimes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["facet", "regime"],
        "properties": {
          "facet": { "type": "string" },
          "regime": { "enum": ["ledger-exact", "model-exact", "rule-sourced", "mechanistic"] }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "kind"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["model", "rule"] }
        }
      }
    },
    "reaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "latex"],
      "$comment": "the subtype-specific ids (acid/conjugate_base | base/conjugate_acid | salt/cation/anion) are optional here and required per-subtype by the gate",
      "properties": {
        "text": { "type": "string", "minLength": 1, "$comment": "house ASCII with the <=> equilibrium arrow" },
        "latex": { "type": "string", "minLength": 1, "$comment": "\\rightleftharpoons for the equilibrium" },
        "acid": { "type": "string", "minLength": 1 },
        "acid_name": { "type": "string", "minLength": 1 },
        "acid_latex": { "type": "string", "minLength": 1 },
        "conjugate_base": { "type": "string", "minLength": 1 },
        "base": { "type": "string", "minLength": 1 },
        "base_name": { "type": "string", "minLength": 1 },
        "base_latex": { "type": "string", "minLength": 1 },
        "conjugate_acid": { "type": "string", "minLength": 1 },
        "salt": { "type": "string", "minLength": 1 },
        "salt_name": { "type": "string", "minLength": 1 },
        "salt_latex": { "type": "string", "minLength": 1 },
        "cation": { "type": "string", "minLength": 1 },
        "anion": { "type": "string", "minLength": 1 },
        "common_ion": { "type": "string", "minLength": 1, "$comment": "solubility common-ion variant: one of the salt's own ions, already in solution" },
        "common_ion_latex": { "type": "string", "minLength": 1 },
        "common_ion_molarity_M": { "$ref": "#/$defs/decimalString" }
      }
    },
    "equilibrium_constant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol", "value", "expression_latex", "source"],
      "properties": {
        "symbol": { "type": "string", "minLength": 1, "$comment": "K_a (weak acid) or K_sp (solubility)" },
        "value": { "$ref": "#/$defs/decimalString" },
        "expression_latex": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1, "$comment": "must resolve in docs/SOURCES.md (data-sourced badge)" }
      }
    },
    "ice": {
      "type": "object",
      "additionalProperties": false,
      "description": "The ICE table = the species ledger in concentrations. Every dissolved row's equilibrium_M = initial_M + ν·extent_M (the ledger identity, re-derived by the gate). A row with in_quotient=false is a pure condensed phase (a solid — the Ksp case) with NO concentration (activity 1, excluded from Q). extent_M is the solved extent (weak acid: the reaction extent x; solubility: the molar solubility s), model-exact-then-rounded.",
      "required": ["extent_symbol", "extent_M", "extent_M_display", "species"],
      "properties": {
        "extent_symbol": { "type": "string", "minLength": 1 },
        "extent_M": { "$ref": "#/$defs/decimalString" },
        "extent_M_display": { "$ref": "#/$defs/decimalString" },
        "species": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "latex", "phase", "role", "nu"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "latex": { "type": "string", "minLength": 1 },
              "phase": { "enum": ["s", "l", "g", "aq"] },
              "role": { "enum": ["reactant", "product"] },
              "nu": { "type": "integer", "not": { "const": 0 } },
              "in_quotient": { "type": "boolean", "$comment": "default true; false = a pure solid excluded from Q, which then omits the concentration fields" },
              "initial_M": { "$ref": "#/$defs/decimalString" },
              "change_M": { "$ref": "#/$defs/decimalString" },
              "equilibrium_M": { "$ref": "#/$defs/decimalString" },
              "equilibrium_M_display": { "$ref": "#/$defs/decimalString" }
            }
          }
        }
      }
    },
    "mass_action": {
      "type": "object",
      "additionalProperties": false,
      "description": "The reaction quotient Q evaluated at the committed equilibrium concentrations (the pure solid excluded), which reproduces K (the residual is the machine-check — the gate re-solves the root independently and re-checks Q=K).",
      "required": ["quotient_symbol", "quotient_at_equilibrium", "residual_relative"],
      "properties": {
        "quotient_symbol": { "type": "string", "minLength": 1 },
        "quotient_at_equilibrium": { "$ref": "#/$defs/decimalString" },
        "residual_relative": { "$ref": "#/$defs/decimalString" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "subtype-specific: the weak acid reports hydronium/pH/percent ionization; the buffer adds pKa/buffer ratio/Henderson–Hasselbalch pH + the common-ion 'no buffer' contrast; the weak base adds hydroxide/pOH + the K_w it bridges through; solubility reports molar solubility + g/L. The gate requires the right set per subtype.",
      "properties": {
        "hydronium_M": { "$ref": "#/$defs/decimalString" },
        "hydronium_M_display": { "$ref": "#/$defs/decimalString" },
        "hydroxide_M": { "$ref": "#/$defs/decimalString" },
        "hydroxide_M_display": { "$ref": "#/$defs/decimalString" },
        "pH": { "$ref": "#/$defs/decimalString" },
        "pH_display": { "$ref": "#/$defs/decimalString" },
        "pOH": { "$ref": "#/$defs/decimalString" },
        "pOH_display": { "$ref": "#/$defs/decimalString" },
        "pKa": { "$ref": "#/$defs/decimalString" },
        "pKa_display": { "$ref": "#/$defs/decimalString" },
        "buffer_ratio": { "$ref": "#/$defs/decimalString", "$comment": "equilibrium [A⁻]/[HA]" },
        "buffer_ratio_display": { "$ref": "#/$defs/decimalString" },
        "hh_pH": { "$ref": "#/$defs/decimalString", "$comment": "pH via Henderson–Hasselbalch on the equilibrium concentrations (= −log₁₀[H⁺], the machine-checked identity)" },
        "hh_pH_display": { "$ref": "#/$defs/decimalString" },
        "hydronium_no_buffer_M": { "$ref": "#/$defs/decimalString", "$comment": "[H⁺] of the acid ALONE (no conjugate base) — the common-ion contrast" },
        "hydronium_no_buffer_M_display": { "$ref": "#/$defs/decimalString" },
        "pH_no_buffer": { "$ref": "#/$defs/decimalString" },
        "pH_no_buffer_display": { "$ref": "#/$defs/decimalString" },
        "suppression_factor_display": { "$ref": "#/$defs/decimalString", "$comment": "how many-fold the common ion suppressed ionization (x_no_buffer / x)" },
        "kw": { "$ref": "#/$defs/decimalString", "$comment": "the water ion-product K_w the weak-base pH bridges through ([H⁺]=K_w/[OH⁻])" },
        "percent_ionization": { "$ref": "#/$defs/decimalString" },
        "percent_ionization_display": { "$ref": "#/$defs/decimalString" },
        "molar_solubility_M": { "$ref": "#/$defs/decimalString" },
        "molar_solubility_M_display": { "$ref": "#/$defs/decimalString" },
        "molar_solubility_pure_water_M": { "$ref": "#/$defs/decimalString", "$comment": "common-ion contrast: the molar solubility in PURE water (no common ion) — higher; suppression_factor_display = this / molar_solubility_M" },
        "molar_solubility_pure_water_M_display": { "$ref": "#/$defs/decimalString" },
        "solubility_g_per_L": { "$ref": "#/$defs/decimalString" },
        "solubility_g_per_L_display": { "$ref": "#/$defs/decimalString" },
        "molar_mass_g_per_mol": { "$ref": "#/$defs/decimalString" },
        "proton_count": { "type": "integer", "minimum": 2, "$comment": "polyprotic: the acid's ionizable proton count (= number of stages)" },
        "species_ladder": {
          "type": "array", "minItems": 2,
          "$comment": "polyprotic: the equilibrium concentration of every species in the ionization ladder HₙA → … → the last anion",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "latex", "equilibrium_M", "equilibrium_M_display"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "latex": { "type": "string", "minLength": 1 },
              "equilibrium_M": { "$ref": "#/$defs/decimalString" },
              "equilibrium_M_display": { "$ref": "#/$defs/decimalString" }
            }
          }
        },
        "later_stages": {
          "type": "array",
          "$comment": "polyprotic: stages 2..n as compact, independently re-solvable objects (the gate re-solves each on the previous stage's outputs). Stage 1 is the top-level ice/mass_action.",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["index", "ka_symbol", "ka_value", "expression_latex", "reactant_id", "reactant_latex",
              "anion_id", "anion_latex", "initial_reactant_M", "initial_hydronium_M", "initial_anion_M",
              "extent_M", "extent_M_display", "anion_equilibrium_M", "anion_equilibrium_M_display",
              "quotient_at_equilibrium", "residual_relative"],
            "properties": {
              "index": { "type": "integer", "minimum": 2 },
              "ka_symbol": { "type": "string", "minLength": 1 },
              "ka_value": { "$ref": "#/$defs/decimalString" },
              "expression_latex": { "type": "string", "minLength": 1 },
              "reactant_id": { "type": "string", "minLength": 1 },
              "reactant_latex": { "type": "string", "minLength": 1 },
              "anion_id": { "type": "string", "minLength": 1 },
              "anion_latex": { "type": "string", "minLength": 1 },
              "initial_reactant_M": { "$ref": "#/$defs/decimalString" },
              "initial_hydronium_M": { "$ref": "#/$defs/decimalString" },
              "initial_anion_M": { "$ref": "#/$defs/decimalString" },
              "extent_M": { "$ref": "#/$defs/decimalString" },
              "extent_M_display": { "$ref": "#/$defs/decimalString" },
              "anion_equilibrium_M": { "$ref": "#/$defs/decimalString" },
              "anion_equilibrium_M_display": { "$ref": "#/$defs/decimalString" },
              "quotient_at_equilibrium": { "$ref": "#/$defs/decimalString" },
              "residual_relative": { "$ref": "#/$defs/decimalString" }
            }
          }
        }
      }
    },
    "misconception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "refuted_by"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "refuted_by": { "type": "string" }
      }
    },
    "reference_links": { "type": "array", "items": { "type": "string" } },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "the machine-checked facts, SHOWN not asserted. All const true — the solver refuses to emit otherwise (ADR-0008). The 4th (ph_consistent | hh_consistent | kw_consistent | solubility_consistent) is subtype-specific.",
      "required": ["ice_identity", "mass_action_satisfied", "extent_physical"],
      "properties": {
        "ice_identity": { "const": true },
        "mass_action_satisfied": { "const": true },
        "extent_physical": { "const": true },
        "ph_consistent": { "const": true },
        "hh_consistent": { "const": true },
        "kw_consistent": { "const": true },
        "solubility_consistent": { "const": true }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "version", "author", "created", "sources"],
      "properties": {
        "producer": { "const": "chemkernel" },
        "version": { "type": "string" },
        "python": { "type": "string" },
        "author": { "type": "string" },
        "created": { "type": "string" },
        "sources": {
          "type": "object",
          "additionalProperties": false,
          "$comment": "the weak acid cites ionization_constants + ion_charge; solubility cites solubility_products + ion_charge + atomic_weight. validate-solutions enforces the subtype-appropriate set + non-empty (schema strictRequired can't follow required names across subschemas, so the subtype cross-field constraints live in the gate).",
          "properties": {
            "ionization_constants": { "type": "string", "minLength": 1 },
            "solubility_products": { "type": "string", "minLength": 1 },
            "ion_charge": { "type": "string", "minLength": 1 },
            "atomic_weight": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
