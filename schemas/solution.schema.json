{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affinity/schemas/solution.schema.json",
  "title": "Affinity solution object",
  "description": "One verified lesson emitted by ChemKernel (ADR-0019). One schema with optional blocks (ADR-0020). additionalProperties:false everywhere.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "title", "slug", "topic", "scenario", "regimes", "assumptions", "given",
    "equations", "ledger", "dimensional_analysis", "result", "misconception",
    "checks", "provenance"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "topic": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "scenario": { "type": "string", "minLength": 1 },
    "regimes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["facet", "regime"],
        "properties": {
          "facet": { "type": "string" },
          "regime": { "enum": ["ledger-exact", "model-exact", "rule-sourced", "mechanistic"] }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "kind"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["model", "rule"] }
        }
      }
    },
    "given": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["species", "moles"],
        "properties": {
          "species": { "type": "string" },
          "volume_mL": { "type": "string" },
          "molarity_M": { "type": "string" },
          "mass_g": { "type": "string" },
          "moles": { "type": "string" }
        }
      }
    },
    "equations": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "Only `molecular` is required: a fully molecular reaction (gas-phase combustion, ADR-0043) has no ions in solution, so the complete/net ionic views are omitted rather than echoing the molecular equation.",
      "required": ["molecular"],
      "properties": {
        "molecular": { "$ref": "#/$defs/equation" },
        "complete_ionic": { "$ref": "#/$defs/equation" },
        "net_ionic": { "$ref": "#/$defs/equation" },
        "spectators": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extent_symbol", "extent_mol", "limiting", "species"],
      "properties": {
        "extent_symbol": { "type": "string" },
        "extent_mol": { "type": "string" },
        "limiting": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "species": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "latex", "phase", "charge", "nu", "initial_mol", "final_mol", "role"],
            "properties": {
              "id": { "type": "string" },
              "latex": { "type": "string" },
              "phase": { "enum": ["s", "l", "g", "aq", null] },
              "charge": { "type": "integer" },
              "nu": { "type": "integer" },
              "initial_mol": { "type": "string" },
              "final_mol": { "type": "string" },
              "role": { "enum": ["limiting", "excess", "product"] }
            }
          }
        }
      }
    },
    "dimensional_analysis": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "steps"],
        "properties": {
          "target": { "type": "string" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value", "unit", "note"],
              "properties": {
                "value": { "type": "string" },
                "unit": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "The reported product is the net-ionic product: `precipitate` (a solid, precipitation lessons) or the general `product` (water for neutralization, ADR-0037; or a collected gas for gas stoichiometry, ADR-0041) — exactly one is present, UNLESS the headline is `energy` (the energy ledger, ADR-0043: q = ΔH_rxn·ξ, no product mass). `salt` names the dissolved ionic product left in solution. `gas` adds the collected gas's volume via PV=nRT. The gates read precipitate ?? product.",
      "required": ["limiting_species", "leftover"],
      "properties": {
        "precipitate": { "$ref": "#/$defs/reportedProduct" },
        "product": { "$ref": "#/$defs/reportedProduct" },
        "salt": { "$ref": "#/$defs/reportedProduct" },
        "gas": {
          "type": "object",
          "additionalProperties": false,
          "description": "Gas-stoichiometry payoff (ADR-0041): the collected gas's VOLUME from PV=nRT at the stated conditions. `moles` are ledger-exact; `volume_L` is model-exact-then-rounded (ideal gas). check-ledger re-derives V=nRT/P numerically.",
          "required": ["species", "phase", "moles", "pressure_atm", "temperature_K", "gas_constant", "gas_constant_source", "volume_L", "volume_L_display", "molar_volume_L_per_mol_display"],
          "properties": {
            "species": { "type": "string" },
            "phase": { "const": "g" },
            "moles": { "type": "string" },
            "pressure_atm": { "type": "string" },
            "temperature_K": { "type": "string" },
            "temperature_C": { "type": "string" },
            "gas_constant": { "type": "string" },
            "gas_constant_source": { "type": "string", "minLength": 1 },
            "volume_L": { "type": "string" },
            "volume_L_display": { "type": "string" },
            "molar_volume_L_per_mol_display": { "type": "string" }
          }
        },
        "energy": {
          "type": "object",
          "additionalProperties": false,
          "description": "Energy-ledger payoff (ADR-0043): the heat q = ΔH_rxn·ξ. ΔH_rxn is assembled by Hess's law from the sourced ΔH_f° (the `hess` breakdown), exact Decimal arithmetic; ξ is ledger-exact; q is exact. The relations (Hess's law, q = ΔH_rxn·ξ at constant P) are model-assumed. check-ledger re-derives the Hess sum + q.",
          "required": ["delta_h_rxn_kj_per_mol", "extent_mol", "q_kj", "q_kj_display", "classification", "source", "hess"],
          "properties": {
            "delta_h_rxn_kj_per_mol": { "type": "string" },
            "extent_mol": { "type": "string" },
            "q_kj": { "type": "string" },
            "q_kj_display": { "type": "string" },
            "classification": { "enum": ["exothermic", "endothermic", "thermoneutral"] },
            "source": { "type": "string", "minLength": 1 },
            "hess": {
              "type": "array",
              "minItems": 2,
              "$comment": "one row per reactant and product; contribution = (product ? +1 : -1)·coeff·ΔH_f°, and Σ contributions = ΔH_rxn (re-derived by check-ledger).",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["species", "role", "coeff", "phase", "is_element", "delta_h_f_kj_per_mol", "contribution_kj_per_mol"],
                "properties": {
                  "species": { "type": "string" },
                  "role": { "enum": ["reactant", "product"] },
                  "coeff": { "type": "integer", "minimum": 1 },
                  "phase": { "enum": ["s", "l", "g", "aq"] },
                  "is_element": { "type": "boolean" },
                  "delta_h_f_kj_per_mol": { "type": "string" },
                  "contribution_kj_per_mol": { "type": "string" }
                }
              }
            }
          }
        },
        "limiting_species": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "leftover": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["species", "moles"],
            "properties": {
              "species": { "type": "string" },
              "moles": { "type": "string" }
            }
          }
        },
        "percent_yield": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional (ADR-0029): actual vs. theoretical yield. Theoretical = the precipitate mass; percent re-derived by check-ledger.",
          "required": ["theoretical_mass_g", "theoretical_display", "actual_mass_g", "actual_display", "percent_display"],
          "properties": {
            "theoretical_mass_g": { "type": "string" },
            "theoretical_display": { "type": "string" },
            "actual_mass_g": { "type": "string" },
            "actual_display": { "type": "string" },
            "percent_display": { "type": "string" }
          }
        }
      }
    },
    "solubility_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["species", "soluble", "rule_id", "statement", "source"],
      "properties": {
        "species": { "type": "string" },
        "soluble": { "type": "boolean" },
        "rule_id": { "type": "string" },
        "statement": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "misconception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "refuted_by"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "refuted_by": { "type": "string" }
      }
    },
    "visualizations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "mode"],
        "properties": {
          "kind": { "type": "string" },
          "mode": { "enum": ["static", "interactive"] },
          "annotate": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "reference_links": { "type": "array", "items": { "type": "string" } },
    "interactive": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional slider instrument (ADR-0011): parity-verified closed forms (ADR-0008) the browser evaluates. Emitted only for the supported single-precipitate double-displacement shape.",
      "required": ["params", "closed_form_params", "closed_form", "cation", "anion", "product", "spectators", "leftover_keys", "samples"],
      "properties": {
        "params": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "label", "species", "kind", "unit", "min", "max", "default", "step"],
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "species": { "type": "string" },
              "kind": { "enum": ["volume", "concentration"] },
              "unit": { "type": "string" },
              "min": { "type": "string" },
              "max": { "type": "string" },
              "default": { "type": "string" },
              "step": { "type": "string" }
            }
          }
        },
        "closed_form_params": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "closed_form": { "type": "object", "additionalProperties": { "type": "string" }, "minProperties": 1 },
        "cation": { "$ref": "#/$defs/ionrole" },
        "anion": { "$ref": "#/$defs/ionrole" },
        "product": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "molar_mass", "phase", "net_coeff"],
          "properties": {
            "id": { "type": "string" },
            "molar_mass": { "type": "string" },
            "phase": { "enum": ["s", "l", "g", "aq"] },
            "net_coeff": { "type": "integer" }
          }
        },
        "spectators": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "source", "per", "key"],
            "properties": {
              "id": { "type": "string" },
              "source": { "type": "string" },
              "per": { "type": "integer" },
              "key": { "type": "string" }
            }
          }
        },
        "leftover_keys": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cation", "anion"],
          "properties": {
            "cation": { "type": "string" },
            "anion": { "type": "string" }
          }
        },
        "samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["args", "expect"],
            "properties": {
              "args": { "type": "object", "additionalProperties": { "type": "string" } },
              "expect": { "type": "object", "additionalProperties": { "type": "string" } }
            }
          }
        }
      }
    },
    "practice": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional generated practice (ADR-0011, brief §6.8): deterministic solver-verified variants. Answers re-derived in Node via the interactive closed forms, or — for gas stoichiometry (ADR-0041) — from the `gas` constants block (check-parity).",
      "required": ["family", "seed", "questions"],
      "properties": {
        "family": { "type": "string" },
        "seed": { "type": "integer" },
        "gas": {
          "type": "object",
          "additionalProperties": false,
          "description": "Gas-stoichiometry practice (ADR-0041): the reaction constants check-parity re-derives every answer from (metal molar mass + coefficients + R, T, P). Present iff there is no interactive block.",
          "required": ["metal_id", "metal_molar_mass", "metal_coeff", "acid_id", "acid_coeff", "gas_id", "gas_coeff", "gas_constant", "temperature_K", "pressure_atm"],
          "properties": {
            "metal_id": { "type": "string" },
            "metal_molar_mass": { "type": "string" },
            "metal_coeff": { "type": "integer" },
            "acid_id": { "type": "string" },
            "acid_coeff": { "type": "integer" },
            "gas_id": { "type": "string" },
            "gas_coeff": { "type": "integer" },
            "gas_constant": { "type": "string" },
            "temperature_K": { "type": "string" },
            "pressure_atm": { "type": "string" }
          }
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "mode", "prompt", "given", "args", "answer", "explain"],
            "$comment": "mode discriminates the response (ADR-0032): 'choice' carries `choices` (categorical — which reagent limits); 'numeric' carries `diagnostics` (free-entry — mass, leftover). check-parity.mjs enforces the per-mode shape.",
            "properties": {
              "id": { "type": "string" },
              "kind": { "enum": ["limiting", "mass", "leftover", "volume"] },
              "mode": { "enum": ["choice", "numeric"] },
              "prompt": { "type": "string", "minLength": 1 },
              "given": {
                "type": "array",
                "minItems": 1,
                "$comment": "a given is a solution (volume_mL + molarity_M) or a weighed mass (mass_g, gas stoichiometry — ADR-0041); species is always present.",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["species"],
                  "properties": {
                    "species": { "type": "string" },
                    "volume_mL": { "type": "string" },
                    "molarity_M": { "type": "string" },
                    "mass_g": { "type": "string" }
                  }
                }
              },
              "args": { "type": "object", "additionalProperties": { "type": "string" } },
              "answer": {
                "type": "object",
                "additionalProperties": false,
                "required": ["display", "value"],
                "properties": {
                  "display": { "type": "string" },
                  "value": { "type": "string" },
                  "unit": { "type": "string" }
                }
              },
              "choices": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["display", "correct"],
                  "properties": {
                    "display": { "type": "string" },
                    "correct": { "type": "boolean" },
                    "misconception": { "type": ["string", "null"] }
                  }
                }
              },
              "diagnostics": {
                "type": "array",
                "$comment": "free-entry mistake catalogue (ADR-0032): a wrong VALUE a named mistake produces, used to diagnose what the learner typed.",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["value", "unit", "misconception"],
                  "properties": {
                    "value": { "type": "string" },
                    "unit": { "type": "string" },
                    "misconception": { "type": "string", "minLength": 1 }
                  }
                }
              },
              "explain": { "type": "string" }
            }
          }
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atom_balance", "charge_balance", "unit_check", "extent_nonnegative"],
      "properties": {
        "atom_balance": { "const": true },
        "charge_balance": { "const": true },
        "unit_check": { "const": true },
        "extent_nonnegative": { "const": true }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "version", "author", "created", "sources"],
      "properties": {
        "producer": { "const": "chemkernel" },
        "version": { "type": "string" },
        "python": { "type": "string" },
        "author": { "type": "string" },
        "created": { "type": "string" },
        "sources": {
          "type": "object",
          "additionalProperties": false,
          "$comment": "solubility is present for precipitation lessons; a neutralization omits it (ADR-0037); a gas-stoichiometry lesson cites `constants` (the gas constant R the volume rides on, ADR-0041); an energy-ledger lesson cites `formation_enthalpies` (the ΔH_f° the Hess sum rides on, ADR-0043).",
          "required": ["atomic_weight", "ion_charge"],
          "properties": {
            "atomic_weight": { "type": "string", "minLength": 1 },
            "ion_charge": { "type": "string", "minLength": 1 },
            "solubility": { "type": "string", "minLength": 1 },
            "constants": { "type": "string", "minLength": 1 },
            "formation_enthalpies": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  },
  "$defs": {
    "reportedProduct": {
      "type": "object",
      "additionalProperties": false,
      "required": ["species", "phase", "molar_mass_g_per_mol", "moles", "mass_g", "mass_g_display"],
      "properties": {
        "species": { "type": "string" },
        "phase": { "enum": ["s", "l", "g", "aq"] },
        "molar_mass_g_per_mol": { "type": "string" },
        "moles": { "type": "string" },
        "mass_g": { "type": "string" },
        "mass_g_display": { "type": "string" }
      }
    },
    "equation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "latex"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "latex": { "type": "string", "minLength": 1 }
      }
    },
    "ionrole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "per", "net_coeff"],
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string" },
        "per": { "type": "integer" },
        "net_coeff": { "type": "integer" }
      }
    }
  }
}
