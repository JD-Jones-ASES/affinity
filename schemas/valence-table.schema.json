{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affinity/schemas/valence-table.schema.json",
  "title": "Affinity Valence Table",
  "description": "The periodic lens: elements in IUPAC positions + sourced ion charges + verified charge-balance salts (ADR-0012/0017). additionalProperties:false everywhere.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "title", "blurb", "group_charge_note", "highlight", "elements", "polyatomic", "charge_balance", "sources"],
  "properties": {
    "kind": { "const": "valence-table" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "blurb": { "type": "string", "minLength": 1 },
    "group_charge_note": { "type": "string", "minLength": 1 },
    "highlight": { "type": "array", "items": { "type": "string" } },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "Z", "name", "atomic_weight", "group", "period", "block"],
        "properties": {
          "symbol": { "type": "string" },
          "Z": { "type": "integer" },
          "name": { "type": "string" },
          "atomic_weight": { "type": "string" },
          "group": { "type": "integer" },
          "period": { "type": "integer" },
          "block": { "type": "string" },
          "common_ion": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "charge", "name", "latex"],
            "properties": {
              "id": { "type": "string" },
              "charge": { "type": "integer" },
              "name": { "type": "string" },
              "latex": { "type": "string" }
            }
          }
        }
      }
    },
    "polyatomic": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "formula", "charge", "name", "latex"],
        "properties": {
          "id": { "type": "string" },
          "formula": { "type": "string" },
          "charge": { "type": "integer" },
          "name": { "type": "string" },
          "latex": { "type": "string" }
        }
      }
    },
    "charge_balance": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cation", "anion", "cation_n", "anion_n", "formula", "latex", "note"],
        "properties": {
          "cation": { "type": "string" },
          "anion": { "type": "string" },
          "cation_n": { "type": "integer", "minimum": 1 },
          "anion_n": { "type": "integer", "minimum": 1 },
          "formula": { "type": "string" },
          "latex": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atomic_weight", "position", "ion_charge"],
      "properties": {
        "atomic_weight": { "type": "string", "minLength": 1 },
        "position": { "type": "string", "minLength": 1 },
        "ion_charge": { "type": "string", "minLength": 1 }
      }
    }
  }
}
