{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affinity/schemas/reference.schema.json",
  "title": "Affinity Chemical Atlas concept entry",
  "description": "One authored reference concept (ADR-0005). additionalProperties:false everywhere.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "title", "term", "definition", "related", "lessons"],
  "properties": {
    "kind": { "const": "concept" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "term": { "type": "string", "minLength": 1 },
    "definition": { "type": "string", "minLength": 1 },
    "regime": { "enum": ["ledger-exact", "model-exact", "rule-sourced", "mechanistic"] },
    "latex": { "type": "string" },
    "related": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["to", "type"],
        "properties": {
          "to": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "type": { "type": "string", "minLength": 1 }
        }
      }
    },
    "lessons": { "type": "array", "items": { "type": "string" } }
  }
}
