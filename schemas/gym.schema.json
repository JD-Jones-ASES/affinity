{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affinity/schemas/gym.schema.json",
  "title": "Affinity procedural gym (generated, verified problem set)",
  "description": "A producer-generated gym: a seeded set of machine-verified drill problems in one family (ADR-0024; extended through Phase 2). Families span dimensional analysis, ionic nomenclature, balancing, mass/limiting/percent-yield stoichiometry, periodic trends, reaction families, gas laws, calorimetry, Lewis structures, weak-acid pH, and kinetics — 13 gyms as of ADR-0049. Numeric-answer kinds are free-entry drills carrying a diagnostics catalogue; categorical kinds carry a choice menu (ADR-0032). additionalProperties:false everywhere.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "title", "slug", "topic", "family", "seed", "problems", "provenance"],
  "properties": {
    "kind": { "const": "gym" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "topic": { "type": "string", "minLength": 1 },
    "family": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer" },
    "blurb": { "type": "string" },
    "skills": { "type": "array", "items": { "type": "string" } },
    "reference_links": { "type": "array", "items": { "type": "string" } },
    "problems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "$comment": "mode discriminates the response: 'choice' carries `choices` (categorical answers), 'numeric' carries `diagnostics` (free-entry answers, ADR-0032). chain/target_unit are present for conversion/stoichiometry, absent for nomenclature; the per-mode/per-kind shape is enforced by validate-gyms.mjs.",
        "required": ["id", "kind", "mode", "prompt", "answer", "derivation", "explain"],
        "properties": {
          "id": { "type": "string", "pattern": "^q[0-9]+$" },
          "kind": { "type": "string", "minLength": 1 },
          "mode": { "enum": ["choice", "numeric"] },
          "prompt": { "type": "string", "minLength": 1 },
          "subscript_tokens": { "type": "array", "items": { "type": "string" } },
          "chain": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value", "unit", "note"],
              "properties": {
                "value": { "type": "string" },
                "unit": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          },
          "target_unit": { "type": "string", "minLength": 1 },
          "answer": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "display"],
            "properties": {
              "value": { "type": "string" },
              "unit": { "type": "string" },
              "display": { "type": "string" }
            }
          },
          "derivation": {
            "type": "object",
            "additionalProperties": false,
            "$comment": "conversion kinds carry `inputs`; nomenclature kinds carry `cation`/`anion`/`formula`/`name`; balancing carries `species`/`coefficients`/`elements`/`archetype`; periodic-trends kinds carry `property`/`series`/`candidates` or `element`/`ion` (ADR-0034, cross-checked against valence-table.json). validate-gyms re-derives each.",
            "required": ["kind"],
            "properties": {
              "kind": {
                "enum": ["volume_molarity_to_moles", "moles_molarity_to_volume", "mass_to_moles", "moles_to_mass", "volume_molarity_to_mass", "ionic_formula_to_name", "ionic_name_to_formula", "balancing", "mass_stoichiometry", "percent_yield", "limiting_mass", "trend_compare", "predict_ion", "order_ionization", "classify_family", "name_spectators", "gas_ideal", "gas_combined", "calorimetry", "lewis_valence", "lewis_domains", "lewis_geometry", "weak_acid_ph", "kinetics_concentration", "kinetics_half_life", "kinetics_order"]
              },
              "inputs": {
                "type": "object",
                "additionalProperties": false,
                "required": ["substance"],
                "properties": {
                  "substance": { "type": "string" },
                  "v_mL": { "type": "string" },
                  "c_M": { "type": "string" },
                  "n_mol": { "type": "string" },
                  "m_g": { "type": "string" },
                  "molar_mass_g_per_mol": { "type": "string" }
                }
              },
              "cation": { "$ref": "#/$defs/ionpart" },
              "anion": { "$ref": "#/$defs/ionpart" },
              "formula": { "type": "string" },
              "name": { "type": "string" },
              "archetype": { "type": "string", "minLength": 1 },
              "species": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/balancespecies" } },
              "coefficients": { "type": "array", "minItems": 2, "items": { "type": "integer", "minimum": 1 } },
              "elements": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[A-Z][a-z]?$" } },
              "given": { "$ref": "#/$defs/stoichpart" },
              "target": { "$ref": "#/$defs/stoichpart" },
              "reactants": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/stoichpart" } },
              "limiting_index": { "type": "integer", "minimum": 0 },
              "actual_mass_g": { "type": "string" },
              "theoretical_mass_g": { "type": "string" },
              "property": { "enum": ["covalent_radius_pm", "first_ionization_kj_mol", "electronegativity"] },
              "direction": { "enum": ["max", "min"] },
              "series": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "n"],
                "properties": {
                  "kind": { "enum": ["period", "group"] },
                  "n": { "type": "integer", "minimum": 1 }
                }
              },
              "candidates": {
                "type": "array",
                "minItems": 3,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["symbol", "value"],
                  "properties": {
                    "symbol": { "type": "string", "pattern": "^[A-Z][a-z]?$" },
                    "value": { "type": "string", "minLength": 1 }
                  }
                }
              },
              "element": { "type": "string", "pattern": "^[A-Z][a-z]?$" },
              "ion": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "charge"],
                "properties": {
                  "id": { "type": "string" },
                  "charge": { "type": "integer" }
                }
              },
              "family": {
                "enum": ["combustion", "synthesis", "decomposition", "single-replacement", "double-replacement", "precipitation", "acid-base", "gas-evolution"]
              },
              "net_species": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/balancespecies" } },
              "net_coefficients": { "type": "array", "minItems": 2, "items": { "type": "integer", "minimum": 1 } },
              "spectators": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "gas": {
                "type": "object",
                "additionalProperties": false,
                "$comment": "gas-law kinds (ADR-0040): the target variable + the given state values (all decimal strings). gas_ideal carries R + three of P_atm/V_L/n_mol/T_K; gas_combined carries P1/V1/T1 + two of P2/V2/T2. validate-gyms re-derives PV=nRT (or the combined law) numerically.",
                "required": ["solve_for"],
                "properties": {
                  "solve_for": { "type": "string", "minLength": 1 },
                  "R": { "type": "string" },
                  "P_atm": { "type": "string" }, "V_L": { "type": "string" },
                  "n_mol": { "type": "string" }, "T_K": { "type": "string" },
                  "P1_atm": { "type": "string" }, "V1_L": { "type": "string" }, "T1_K": { "type": "string" },
                  "P2_atm": { "type": "string" }, "V2_L": { "type": "string" }, "T2_K": { "type": "string" }
                }
              },
              "calorimetry": {
                "type": "object",
                "additionalProperties": false,
                "$comment": "calorimetry kind (ADR-0042): the target variable + the sourced substance + the three given values of q_J/m_g/c_JgK/dT_K (all decimal strings). validate-gyms re-derives q = m·c·ΔT numerically.",
                "required": ["solve_for", "substance"],
                "properties": {
                  "solve_for": { "type": "string", "minLength": 1 },
                  "substance": { "type": "string", "minLength": 1 },
                  "q": { "type": "string" }, "m": { "type": "string" },
                  "c": { "type": "string" }, "dT": { "type": "string" }
                }
              },
              "equilibrium": {
                "type": "object",
                "additionalProperties": false,
                "$comment": "weak_acid_ph kind (ADR-0048): the sourced weak acid + its Kₐ + formal concentration [HA]₀ (decimal strings). validate-gyms re-solves the mass-action root (Q=Kₐ) in pure Node (shared equilibriumcheck.mjs) and re-checks pH = −log₁₀[H⁺].",
                "required": ["acid", "ka", "c0"],
                "properties": {
                  "acid": { "type": "string", "minLength": 1 },
                  "ka": { "type": "string", "minLength": 1 },
                  "c0": { "type": "string", "minLength": 1 }
                }
              },
              "lewis": {
                "type": "object",
                "additionalProperties": false,
                "$comment": "Lewis-structure kinds (ADR-0044): the raw structure (atoms + bonds + central + formula + charge) so the gate re-derives the valence total (Σ group electrons − charge, from valence-table.json) and the electron-domain count in pure Node; the geometry kind adds the machine-derived domains/lone_pairs + the sourced molecular_shape.",
                "required": ["formula", "charge", "central", "atoms", "bonds"],
                "properties": {
                  "formula": { "type": "string", "minLength": 1 },
                  "charge": { "type": "integer" },
                  "central": { "type": "string", "minLength": 1 },
                  "atoms": {
                    "type": "array", "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["id", "element", "lone_pairs"],
                      "properties": {
                        "id": { "type": "string", "minLength": 1 },
                        "element": { "type": "string", "pattern": "^[A-Z][a-z]?$" },
                        "lone_pairs": { "type": "integer", "minimum": 0 }
                      }
                    }
                  },
                  "bonds": {
                    "type": "array", "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["a", "b", "order"],
                      "properties": {
                        "a": { "type": "string", "minLength": 1 },
                        "b": { "type": "string", "minLength": 1 },
                        "order": { "type": "integer", "minimum": 1 }
                      }
                    }
                  },
                  "domains": { "type": "integer", "minimum": 2 },
                  "lone_pairs": { "type": "integer", "minimum": 0 },
                  "molecular_shape": { "type": "string", "minLength": 1 }
                }
              },
              "kinetics": {
                "type": "object",
                "additionalProperties": false,
                "$comment": "kinetics kinds (ADR-0049): the reaction order + the sourced rate constant k (native units) + [A]₀; the concentration kind adds the elapsed time t, the order kind adds the three successive half_lives. validate-gyms re-derives [A](t)/t½/the successive half-lives per order in pure Node (shared kineticscheck.mjs).",
                "required": ["order", "k", "k_unit", "c0"],
                "properties": {
                  "order": { "enum": [0, 1, 2] },
                  "k": { "type": "string", "minLength": 1 },
                  "k_unit": { "type": "string", "minLength": 1 },
                  "c0": { "type": "string", "minLength": 1 },
                  "t": { "type": "string", "minLength": 1 },
                  "half_lives": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "string", "minLength": 1 } }
                }
              }
            }
          },
          "choices": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["display", "correct", "misconception"],
              "properties": {
                "display": { "type": "string", "minLength": 1 },
                "correct": { "type": "boolean" },
                "misconception": { "type": ["string", "null"] }
              }
            }
          },
          "diagnostics": {
            "type": "array",
            "$comment": "free-entry mistake catalogue (ADR-0032): a wrong VALUE a named mistake produces, used to diagnose what the learner typed. May be empty when every mistake collides with the answer (e.g. a 1:1 ratio).",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value", "unit", "misconception"],
              "properties": {
                "value": { "type": "string" },
                "unit": { "type": "string" },
                "misconception": { "type": "string", "minLength": 1 }
              }
            }
          },
          "explain": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "version", "sources"],
      "properties": {
        "producer": { "type": "string" },
        "version": { "type": "string" },
        "sources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["atomic_weight"],
          "properties": {
            "atomic_weight": { "type": "string" },
            "position": { "type": "string" },
            "ion_charge": { "type": "string" },
            "electronegativity": { "type": "string" },
            "covalent_radius": { "type": "string" },
            "ionization_energy": { "type": "string" },
            "reaction_classes": { "type": "string" },
            "constants": { "type": "string" },
            "specific_heats": { "type": "string" },
            "vsepr": { "type": "string" },
            "ionization_constants": { "type": "string" },
            "rate_constants": { "type": "string" }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "$comment": "model assumptions disclosed on a regime-2 gym (ADR-0040) — the model-assumed badge; absent on ledger-exact gyms",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "kind"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "ionpart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "formula_part", "charge", "compound_name"],
      "properties": {
        "id": { "type": "string" },
        "formula_part": { "type": "string" },
        "charge": { "type": "integer" },
        "compound_name": { "type": "string" }
      }
    },
    "balancespecies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula", "role", "counts", "charge"],
      "properties": {
        "formula": { "type": "string", "minLength": 1 },
        "role": { "enum": ["reactant", "product"] },
        "counts": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "pattern": "^[A-Z][a-z]?$" },
          "additionalProperties": { "type": "integer", "minimum": 1 }
        },
        "charge": { "type": "integer" }
      }
    },
    "stoichpart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "formula", "coeff", "molar_mass_g_per_mol"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "formula": { "type": "string", "minLength": 1 },
        "coeff": { "type": "integer", "minimum": 1 },
        "molar_mass_g_per_mol": { "type": "string" },
        "mass_g": { "type": "string" }
      }
    }
  }
}
