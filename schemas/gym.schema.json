{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://affinity/schemas/gym.schema.json",
  "title": "Affinity procedural gym (generated, verified problem set)",
  "description": "A Phase-1 gym: producer-generated dimensional-analysis problems (ADR-0024). additionalProperties:false everywhere.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "title", "slug", "topic", "family", "seed", "problems", "provenance"],
  "properties": {
    "kind": { "const": "gym" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "topic": { "type": "string", "minLength": 1 },
    "family": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer" },
    "blurb": { "type": "string" },
    "skills": { "type": "array", "items": { "type": "string" } },
    "reference_links": { "type": "array", "items": { "type": "string" } },
    "problems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "$comment": "chain/target_unit are required for conversion problems, absent for nomenclature; the per-kind shape is enforced by validate-gyms.mjs.",
        "required": ["id", "kind", "prompt", "answer", "derivation", "choices", "explain"],
        "properties": {
          "id": { "type": "string", "pattern": "^q[0-9]+$" },
          "kind": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "subscript_tokens": { "type": "array", "items": { "type": "string" } },
          "chain": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value", "unit", "note"],
              "properties": {
                "value": { "type": "string" },
                "unit": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          },
          "target_unit": { "type": "string", "minLength": 1 },
          "answer": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "display"],
            "properties": {
              "value": { "type": "string" },
              "unit": { "type": "string" },
              "display": { "type": "string" }
            }
          },
          "derivation": {
            "type": "object",
            "additionalProperties": false,
            "$comment": "conversion kinds carry `inputs`; nomenclature kinds carry `cation`/`anion`/`formula`/`name`; balancing carries `species`/`coefficients`/`elements`/`archetype`. validate-gyms re-derives each.",
            "required": ["kind"],
            "properties": {
              "kind": {
                "enum": ["volume_molarity_to_moles", "moles_molarity_to_volume", "mass_to_moles", "moles_to_mass", "volume_molarity_to_mass", "ionic_formula_to_name", "ionic_name_to_formula", "balancing"]
              },
              "inputs": {
                "type": "object",
                "additionalProperties": false,
                "required": ["substance"],
                "properties": {
                  "substance": { "type": "string" },
                  "v_mL": { "type": "string" },
                  "c_M": { "type": "string" },
                  "n_mol": { "type": "string" },
                  "m_g": { "type": "string" },
                  "molar_mass_g_per_mol": { "type": "string" }
                }
              },
              "cation": { "$ref": "#/$defs/ionpart" },
              "anion": { "$ref": "#/$defs/ionpart" },
              "formula": { "type": "string" },
              "name": { "type": "string" },
              "archetype": { "type": "string", "minLength": 1 },
              "species": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/balancespecies" } },
              "coefficients": { "type": "array", "minItems": 2, "items": { "type": "integer", "minimum": 1 } },
              "elements": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[A-Z][a-z]?$" } }
            }
          },
          "choices": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["display", "correct", "misconception"],
              "properties": {
                "display": { "type": "string", "minLength": 1 },
                "correct": { "type": "boolean" },
                "misconception": { "type": ["string", "null"] }
              }
            }
          },
          "explain": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "version", "sources"],
      "properties": {
        "producer": { "type": "string" },
        "version": { "type": "string" },
        "sources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["atomic_weight"],
          "properties": { "atomic_weight": { "type": "string" } }
        }
      }
    }
  },
  "$defs": {
    "ionpart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "formula_part", "charge", "compound_name"],
      "properties": {
        "id": { "type": "string" },
        "formula_part": { "type": "string" },
        "charge": { "type": "integer" },
        "compound_name": { "type": "string" }
      }
    },
    "balancespecies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula", "role", "counts", "charge"],
      "properties": {
        "formula": { "type": "string", "minLength": 1 },
        "role": { "enum": ["reactant", "product"] },
        "counts": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "pattern": "^[A-Z][a-z]?$" },
          "additionalProperties": { "type": "integer", "minimum": 1 }
        },
        "charge": { "type": "integer" }
      }
    }
  }
}
